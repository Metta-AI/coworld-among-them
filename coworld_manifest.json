{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/coworld/main/src/coworld/coworld_manifest_schema.json",
  "game": {
    "name": "among_them",
    "version": "0.1.21",
    "description": "A social deduction BitWorld game with crewmates, imposters, tasks, voting, and betrayal.",
    "owner": "treeform@softmax.com",
    "runnable": {
      "type": "game",
      "image": "public.ecr.aws/s3j4p9s7/treeform/games/among-them:latest",
      "run": [
        "/bin/among_them"
      ],
      "source_url": "https://github.com/Metta-AI/coworld-among-them/tree/88b612784dcbe3d22af6e10be2fa601a54272bc8"
    },
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens",
        "players"
      ],
      "properties": {
        "tokens": {
          "description": "One connection token per player slot, indexed by slot.",
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "players": {
          "description": "One player display-name object per player slot, indexed by slot.",
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "slots": {
          "description": "Optional fixed player slot role, color, and token settings.",
          "type": "array",
          "maxItems": 16,
          "default": [],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "token": {
                "type": "string"
              },
              "role": {
                "type": "string",
                "enum": [
                  "crew",
                  "imposter"
                ]
              },
              "color": {
                "type": "string",
                "enum": [
                  "red",
                  "orange",
                  "yellow",
                  "light blue",
                  "pink",
                  "lime",
                  "blue",
                  "pale blue",
                  "gray",
                  "white",
                  "dark brown",
                  "brown",
                  "dark teal",
                  "green",
                  "dark navy",
                  "black"
                ]
              }
            }
          }
        },
        "closedRoster": {
          "description": "Reject players outside the configured token/slot roster.",
          "type": "boolean",
          "default": false
        },
        "seed": {
          "description": "Random seed.",
          "type": "integer",
          "default": 679961
        },
        "minPlayers": {
          "description": "Players needed before the game countdown starts.",
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "default": 8
        },
        "imposterCount": {
          "description": "Fixed imposter count when autoImposterCount is false.",
          "type": "integer",
          "minimum": 0,
          "maximum": 15,
          "default": 2
        },
        "autoImposterCount": {
          "description": "Automatically choose imposter count from player count.",
          "type": "boolean",
          "default": false
        },
        "tasksPerPlayer": {
          "description": "Tasks assigned to each crewmate.",
          "type": "integer",
          "minimum": 0,
          "default": 8
        },
        "buttonCalls": {
          "description": "Emergency button calls allowed per player.",
          "type": "integer",
          "minimum": 0,
          "default": 1
        },
        "startWaitTicks": {
          "description": "Lobby countdown ticks after enough players join.",
          "type": "integer",
          "minimum": 0,
          "default": 120
        },
        "voteTimerTicks": {
          "description": "Voting phase duration in ticks.",
          "type": "integer",
          "minimum": 1,
          "default": 6000
        },
        "voteResultTicks": {
          "description": "Vote result display duration in ticks.",
          "type": "integer",
          "minimum": 0,
          "default": 72
        },
        "killCooldownTicks": {
          "description": "Kill cooldown duration in ticks.",
          "type": "integer",
          "minimum": 0,
          "default": 900
        },
        "roleRevealTicks": {
          "description": "Role reveal duration in ticks.",
          "type": "integer",
          "minimum": 0,
          "default": 120
        },
        "taskCompleteTicks": {
          "description": "Task completion duration in ticks.",
          "type": "integer",
          "minimum": 0,
          "default": 72
        },
        "messageCooldownTicks": {
          "description": "Chat message cooldown in ticks.",
          "type": "integer",
          "minimum": 0,
          "default": 100
        },
        "gameOverTicks": {
          "description": "Game over display duration in ticks.",
          "type": "integer",
          "minimum": 0,
          "default": 360
        },
        "maxTicks": {
          "description": "Maximum game ticks, where 0 means no limit.",
          "type": "integer",
          "minimum": 0,
          "default": 10000
        },
        "maxGames": {
          "description": "Maximum games before shutdown.",
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "killRange": {
          "description": "Kill interaction range.",
          "type": "integer",
          "minimum": 0,
          "default": 20
        },
        "ventRange": {
          "description": "Vent interaction range.",
          "type": "integer",
          "minimum": 0,
          "default": 16
        },
        "reportRange": {
          "description": "Body report interaction range.",
          "type": "integer",
          "minimum": 0,
          "default": 20
        },
        "showTaskArrows": {
          "description": "Show arrows pointing to tasks.",
          "type": "boolean",
          "default": true
        },
        "showTaskBubbles": {
          "description": "Show task bubbles.",
          "type": "boolean",
          "default": true
        },
        "showPlayerLabels": {
          "description": "Show player labels.",
          "type": "boolean",
          "default": true
        },
        "mapPath": {
          "description": "Map JSON file path.",
          "type": "string",
          "default": "data/map.json"
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scores"
      ],
      "properties": {
        "names": {
          "description": "One player name or address per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "string"
          }
        },
        "scores": {
          "description": "One scalar score per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "number"
          }
        },
        "win": {
          "description": "One win flag per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "boolean"
          }
        },
        "tasks": {
          "description": "One completed task count per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "integer"
          }
        },
        "kills": {
          "description": "One kill count per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "integer"
          }
        },
        "imposter": {
          "description": "One 1 or 0 flag for whether the player was an imposter.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          }
        },
        "crew": {
          "description": "One 1 or 0 flag for whether the player was crew.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1
          }
        },
        "vote_players": {
          "description": "One count of votes cast for a player per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "vote_skip": {
          "description": "One count of explicit skip votes per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "vote_timeout": {
          "description": "One count of vote timeouts per player slot.",
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "protocols": {
      "player": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/bitscreen_v1.md"
      },
      "global": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/bitworld/blob/master/docs/sprite_v1.md"
      }
    },
