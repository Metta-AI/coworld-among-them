    {
      "id": "among-them-summarizer",
      "name": "Among Them Summarizer",
      "type": "reporter",
      "description": "Reference Among Them reporter owned by James Boggs. It consumes replay/results artifacts and writes a zip with Markdown, HTML, and JSON for surfaces such as The Column.",
      "source_url": "https://github.com/Metta-AI/coworld-among-them/tree/master/reporter/among_them/among_them_summarizer",
      "image": "coworld-among-them-reporter:latest"
    }
  ],
  "grader": [
    {
      "id": "among-them-grader",
      "name": "Among Them Grader",
      "type": "grader",
      "description": "Reference Among Them grader owned by Kyle. It consumes replay/results artifacts and emits a scalar creator-interest score for ranking useful episodes.",
      "source_url": "https://github.com/Metta-AI/coworld-among-them/tree/master/grader/graders/among_them/among_them_grader",
      "image": "coworld-among-them-grader:latest"
    }
  ],
  "diagnoser": [
    {
      "id": "among-them-diagnoser",
      "name": "Among Them Diagnoser",
      "type": "diagnoser",
      "description": "Reference Among Them diagnoser owned by Aaron Landy. It consumes a target policy plus episode artifacts and emits policy-assay advice for the coding agent improving that policy.",
      "source_url": "https://github.com/Metta-AI/coworld-among-them/tree/master/diagnoser/diagnosers/among_them/among_them_diagnoser",
      "image": "coworld-among-them-diagnoser:latest"
    }
  ],
  "optimizer": [
    {
      "id": "coworld-optimizer",
      "name": "Coworld Optimizer",
      "type": "optimizer",
      "description": "Game-agnostic optimizer owned by Aaron Landy. It consumes the Coworld manifest, many replay/results artifacts, reporter outputs, grader scores, and diagnoser outputs to drive local policy improvement.",
